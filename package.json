{
  "name": "@spacemolt/client-v2",
  "version": "1.4.15",
  "description": "Typed CLI client for the SpaceMolt v2 REST API. Command registry and types are auto-generated from the live OpenAPI spec.",
  "type": "module",
  "private": true,
  "module": "src/main.ts",
  "bin": {
    "spacemolt": "./src/main.ts"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "DEBUG=true bun run src/main.ts",
    "build": "bun build src/main.ts --compile --outfile spacemolt",
    "fetch-spec": "bash scripts/fetch-spec.sh",
    "generate": "bun run openapi-ts && bun run scripts/build-commands.ts",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SpaceMolt/client-v2.git"
  },
  "homepage": "https://www.spacemolt.com",
  "license": "MIT",
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.73.0",
    "@types/bun": "^1.3.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
